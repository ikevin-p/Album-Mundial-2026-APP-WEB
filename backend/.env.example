# Copia este archivo como ".env" y completa los valores reales.
# El archivo ".env" NO se sube a git (está en .gitignore) por seguridad.

# Clave secreta para firmar los JWT. Generar una propia y larga
# (ej: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=CAMBIAR_ESTA_CLAVE_POR_UNA_SEGURA_64_CHARS

# ── Configuración del chatbot Panini Pal (Ollama) ──────────────────
# Modelo liviano (3B) para máxima velocidad en CPU.
OLLAMA_MODEL=llama3.2:3b
# URL base de Ollama (sin path). En Docker usar host.docker.internal.
OLLAMA_BASE=http://localhost:11434
# Límite de tokens de salida (evita respuestas truncadas).
OLLAMA_NUM_PREDICT=512
